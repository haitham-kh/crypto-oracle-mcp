# CryptoOracle MCP — API Keys
# Copy this to .env and fill in your keys

# Binance (https://www.binance.com/en/my/settings/api-management)
BINANCE_API_KEY=your_binance_api_key_here
BINANCE_API_SECRET=your_binance_api_secret_here

# MEXC (https://www.mexc.com/user/openapi)
MEXC_API_KEY=your_mexc_api_key_here
MEXC_API_SECRET=your_mexc_api_secret_here

# CoinMarketCap (https://coinmarketcap.com/api)
CMC_API_KEY=your_cmc_api_key_here

# CoinGecko (https://www.coingecko.com/en/api — free tier works)
COINGECKO_API_KEY=your_coingecko_api_key_here

# Glassnode (optional — https://glassnode.com)
GLASSNODE_API_KEY=

# Block Explorer API Keys (optional — for top holders)
ETHERSCAN_API_KEY=
BSCSCAN_API_KEY=
